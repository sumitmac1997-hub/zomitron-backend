NODE_ENV=production
HOST=0.0.0.0

# Render injects PORT automatically. You usually do not need to set it manually.

MONGO_URI=your_mongodb_atlas_connection_string
MONGO_DB_NAME=zomitron
USE_MEMORY_DB=false
FALLBACK_MEMORY_DB=false

JWT_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret

CLIENT_URL=https://zomitron.com
ALLOWED_ORIGINS=https://zomitron.com,https://www.zomitron.com

# Leave Redis disabled unless you attach a managed Redis service.
REDIS_ENABLED=false
# REDIS_URL=redis://default:password@host:port

# Add the rest of your production secrets here:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=true
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_FROM=Zomitron <support@zomitron.com>
# GOOGLE_MAPS_API_KEY=
