# --- Database ---
# Atlas URI provided by user (saves to zomitron-DB cluster)
MONGO_URI=mongodb+srv://sumitmac1997_db_user:LK6yCSQGXLkijDfW@zomitron-db.uetg3fw.mongodb.net/?appName=zomitron-DB
